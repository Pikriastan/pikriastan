{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "cli": "deno run --allow-env --allow-read --allow-ffi cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop"
  },
  "imports": {
    "@/": "./",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1060.0",
    "@hugeicons/core-free-icons": "npm:@hugeicons/core-free-icons@^4.2.0",
    "@hugeicons/react": "npm:@hugeicons/react@^1.1.6",
    "@inquirer/prompts": "npm:@inquirer/prompts@^8.5.2",
    "bcryptjs": "npm:bcryptjs@^3.0.3",
    "better-auth": "npm:better-auth@^1.6.14",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "clsx": "npm:clsx@^2.1.1",
    "commander": "npm:commander@^15.0.0",
    "dotenv": "npm:dotenv@^17.4.2",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2",
    "jose": "npm:jose@^6.2.3",
    "kysely": "npm:kysely@0.28.17",
    "next": "npm:next@16.2.7",
    "next-themes": "npm:next-themes@^0.4.6",
    "pg": "npm:pg@^8.21.0",
    "react": "npm:react@19.2.7",
    "react-dom": "npm:react-dom@19.2.7",
    "server-only": "npm:server-only@^0.0.1",
    "sharp": "npm:sharp@^0.34.5",
    "sonner": "npm:sonner@^2.0.7",
    "swr": "npm:swr@^2.4.1",
    "tailwind-merge": "npm:tailwind-merge@^3.6.0",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "uuid": "npm:uuid@^14.0.0",
    "vite-plugin-webfont-dl": "npm:vite-plugin-webfont-dl@^3.12.0",
    "zod": "npm:zod@^4.4.3",
    "@biomejs/biome": "npm:@biomejs/biome@2.4.16",
    "@tailwindcss/postcss": "npm:@tailwindcss/postcss@^4.3.0",
    "@types/node": "npm:@types/node@^25.9.1",
    "@types/pg": "npm:@types/pg@^8.20.0",
    "@types/react": "npm:@types/react@^19.2.16",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "tailwindcss": "npm:tailwindcss@^4.3.0",
    "ultracite": "npm:ultracite@^7.8.1"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx"
  },
  "allowScripts": [
    "npm:esbuild@0.18.20",
    "npm:esbuild@0.25.12",
    "npm:esbuild@0.28.0",
    "npm:sharp@0.34.5"
  ],
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals",
    "unsafe-proto",
    "sloppy-imports"
  ],
  "lint": {
    "rules": {
      "exclude": ["no-sloppy-imports"]
    }
  },
  "exclude": ["node_modules"]
}
